# ═══════════════════════════════════════════════════════
#  NR Fleet Manager — Environment Configuration
#  Copy to .env and fill in the values
#  Run: bash install.sh  (generates this automatically)
# ═══════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────
DB_NAME=nr_fleet
DB_USER=nr_fleet
DB_PASSWORD=change_me_strong_password_here

# ── Security ──────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_minimum_32_characters_long

# ── First Admin User ──────────────────────────────────
# Used only on FIRST startup (when DB is empty)
# Must change password on first login
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change_me_admin_password

# ── Network ───────────────────────────────────────────
# Port to expose the app on
PORT=80

# CORS: comma-separated origins (or * for any)
# Example: http://myserver.com,http://192.168.1.100
ALLOWED_ORIGINS=*

# ── Environment ───────────────────────────────────────
NODE_ENV=production
